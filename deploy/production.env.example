# Env PENGELUARAN PERKIB — salin ke /etc/perkib/.env di pelayan. JANGAN commit nilai sebenar.

NEXT_PUBLIC_SITE_URL=https://perkib.my
NEXT_PUBLIC_SANITY_PROJECT_ID=sk9lh0ym
NEXT_PUBLIC_SANITY_DATASET=production

# Token Editor Sanity (baca+tulis; dataset boleh private)
SANITY_API_TOKEN=
SANITY_WRITE_TOKEN=
SANITY_REVALIDATE_SECRET=

# Enkripsi data sensitif — MESTI sama dengan kunci asal (openssl rand -hex 32)
DATA_ENCRYPTION_KEY=

# Admin (kata laluan kuat) + rahsia sesi berasingan
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
SAGUHATI_TOKEN_SECRET=

# WhatsApp (wassap.wehdah.my) — DRY_RUN=0 untuk hantar sebenar
WASSAP_API_URL=https://wassap.wehdah.my
WASSAP_API_KEY=
WASSAP_DRY_RUN=0

# Staf MAIWP lain (fail terenkripsi + folder foto di pelayan)
STAF_DATA_FILE=/etc/perkib/staf-lain.enc.json
STAF_PHOTO_DIR=/srv/perkib/staf-foto

# Kosongkan di pengeluaran
CAPTCHA_BYPASS_SECRET=

# Emel hubungi
RESEND_API_KEY=dev
CONTACT_FROM_EMAIL=PERKIB <admin@perkib.my>

# Runtime
NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1
TZ=Asia/Kuala_Lumpur
