# Salin ke .env.local dan isi nilai sebenar. JANGAN commit .env.local.

# URL laman (untuk metadata + origin guard)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity — cipta projek di https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Token Editor (Sanity Manage -> API -> Tokens). Untuk seed & tulis permohonan.
# JANGAN prefix dengan NEXT_PUBLIC_!
SANITY_API_TOKEN=
SANITY_WRITE_TOKEN=

# Rahsia webhook revalidate (Sanity -> API -> Webhooks)
SANITY_REVALIDATE_SECRET=

# Rahsia HMAC token pengesahan saguhati (jana: openssl rand -hex 32)
SAGUHATI_TOKEN_SECRET=

# Kata laluan panel admin /admin
ADMIN_PASSWORD=

# Rahsia berasingan untuk menandatangani kuki sesi admin (jana: openssl rand -hex 32).
# Diasingkan drpd ADMIN_PASSWORD supaya tukar kata laluan tidak batalkan tandatangan.
ADMIN_SESSION_SECRET=

# --- v2: Enkripsi data sensitif at-rest (WAJIB untuk simpan IC/telefon/bank) ---
# Kunci AES-256-GCM. Jana: openssl rand -hex 32 (64 aksara hex = 32 bait).
# ⚠️ HILANG KUNCI = HILANG SEMUA IC/TELEFON/BANK TERENKRIPSI. Simpan salinan selamat.
DATA_ENCRYPTION_KEY=

# --- v2: Notifikasi WhatsApp melalui wassap.wehdah.my ---
WASSAP_API_URL=https://wassap.wehdah.my
# Kunci API (skop messages:send) dari dashboard wassap.wehdah.my. JANGAN commit.
WASSAP_API_KEY=
# "1" = mod ujian (log sahaja, tidak hantar mesej sebenar). Kosong/"0" = hantar betul.
WASSAP_DRY_RUN=1

# --- v2: Direktori staf MAIWP lain (admin sahaja) ---
# Fail JSON terenkripsi (dijana oleh scripts/build-staf-lain.ts). Relatif ke root projek.
STAF_DATA_FILE=private-data/staf-lain.enc.json
# Folder foto staf lain (dihidang melalui route berdaftar admin sahaja).
STAF_PHOTO_DIR=

# Rahsia pintasan captcha untuk automasi ujian E2E sahaja (kosongkan di produksi).
CAPTCHA_BYPASS_SECRET=

# Resend (borang hubungi). "dev" = mod log sahaja, tidak hantar emel.
RESEND_API_KEY=dev
CONTACT_FROM_EMAIL=

TZ=Asia/Kuala_Lumpur
